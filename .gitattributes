# Normalize all text files to LF in the repo and working tree.
# Matches Prettier (endOfLine: lf) so files don't show as phantom-modified.
* text=auto eol=lf

# Binary assets — never touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.mp4 binary
*.woff binary
*.woff2 binary
